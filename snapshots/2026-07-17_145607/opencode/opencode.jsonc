{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "bigmodel",
    "figure",
    "jamiexujamiexu",
    "jan"
  ],
  "provider": {
    "bigmodel": {
      "name": "bigmodel",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/coding/paas/v4"
      },
      "models": {
        "gml-5.2": {
          "name": "GML-5.2"
        }
      }
    },
    "figure": {
      "name": "figuer",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://figure.jiangsuocean.cn/v1"
      },
      "models": {
        "glm-5.2": {
          "name": "glm5.2"
        }
      }
    },
    "jamiexujamiexu": {
      "name": "jamiexu",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://ai.jamiexu.cn/v1"
      },
      "models": {
        "glm-5.2": {
          "name": "glm-5.2"
        }
      }
    },
    "jamiexu": {
      "name": "https://ai.jamiexu.cn/",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://ai.jamiexu.cn/v1"
      },
      "models": {
        "glm-5.2": {
          "name": "GLM5.2"
        }
      }
    },
    "jan": {
      "name": "jan",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://ai.jamiexu.cn/v1"
      },
      "models": {
        "glm-5.2": {
          "name": "GML52"
        }
      }
    },
    "padi": {
      "name": "padi",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://padi.closeai.hk/v1"
      },
      "models": {
        "gpt-5.6-sol": {
          "name": "gpt-5.6-sol"
        },
        "gpt-5.6": {
          "name": "gpt-5.6"
        },
        "gpt-5.6-terra": {
          "name": "gpt-5.6-terra"
        },
        "gpt-5.6-luna": {
          "name": "gpt-5.6-luna"
        },
        "gpt-5.5": {
          "name": "gpt-5.5"
        },
        "gpt-5.4": {
          "name": "gpt-5.4"
        },
        "gpt-5.4-mini": {
          "name": "gpt-5.4-mini"
        },
        "gpt-5.2": {
          "name": "gpt-5.2"
        },
        "gpt-5.3-codex-spark": {
          "name": "gpt-5.3-codex-spark"
        },
        "codex-auto-review": {
          "name": "codex-auto-review"
        },
        "gpt-image-1": {
          "name": "gpt-image-1"
        },
        "gpt-image-1.5": {
          "name": "gpt-image-1.5"
        },
        "gpt-image-2": {
          "name": "gpt-image-2"
        }
      }
    }
  }
}